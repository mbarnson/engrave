# Engrave API Keys
#
# Copy this file to .env and fill in your API keys.
# This file is gitignored -- never commit actual keys.
#
# These override values in engrave.toml via pydantic-settings
# using the ENGRAVE_ prefix and __ nested delimiter.

# Anthropic API key (for roles using anthropic/ model prefix)
ENGRAVE_PROVIDERS__ANTHROPIC_API_KEY=

# OpenAI API key (for roles using openai/ model prefix)
ENGRAVE_PROVIDERS__OPENAI_API_KEY=

# RunPod API key (for roles using hosted_vllm/ or runpod/ model prefix)
ENGRAVE_PROVIDERS__RUNPOD__API_KEY=

# Agent SDK API key (for desktop app users using agent_sdk/ model prefix)
# Get your key at https://console.anthropic.com/
ENGRAVE_PROVIDERS__AGENT_SDK__API_KEY=

# LM Studio typically needs no API key (local), but you can set one:
# ENGRAVE_PROVIDERS__LM_STUDIO__API_KEY=
