{
  "identifier": "default",
  "description": "Default permissions for the Engrave desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "engrave-generate",
          "cmd": "engrave",
          "args": true
        },
        {
          "name": "engrave-render",
          "cmd": "engrave",
          "args": true
        }
      ]
    },
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "os:default"
  ]
}
