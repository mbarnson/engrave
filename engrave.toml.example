# Engrave runtime configuration
#
# Copy this file to engrave.toml and edit as needed.
# API keys go in .env (see .env.example), not here.
#
# Priority chain: env vars > .env > engrave.toml > defaults

[providers.lm_studio]
# Local LM Studio endpoint (default for development on Apple Silicon)
api_base = "http://localhost:1234/v1"

[providers.runpod]
# RunPod serverless vLLM endpoint (uncomment and set your endpoint ID)
# api_base = "https://api.runpod.ai/v2/YOUR-ENDPOINT-ID/openai/v1"

# --- Role-based model mapping ---
# Each role maps to a provider+model. Swap models by changing one line.
# Model strings use LiteLLM provider prefixes:
#   claude_pipe/<model>    - Claude via `claude -p` pipe mode (default)
#   lm_studio/<model>      - Local LM Studio
#   anthropic/<model>      - Anthropic API
#   openai/<model>         - OpenAI API
#   hosted_vllm/<model>    - RunPod/vLLM endpoint

[roles.compile_fixer]
model = "claude_pipe/haiku"
tags = ["code"]

[roles.generator]
model = "claude_pipe/haiku"
tags = ["code", "lilypond"]

[roles.describer]
model = "anthropic/claude-sonnet-4-20250514"
tags = ["audio", "description"]

[lilypond]
min_version = "2.24"
compile_timeout = 60
max_fix_attempts = 5
context_lines = 20
